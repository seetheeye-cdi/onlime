# Onlime Configuration
# Copy to onlime.toml and customize.

[vault]
root = "~/Documents/Obsidian/Onlime"

[state]
dir = "~/.onlime"

[general]
timezone = "Asia/Seoul"
log_level = "INFO"

[kakao]
enabled = true
use_kakaocli = true                       # kakaocli DB polling (preferred)
poll_interval_minutes = 30
sync_days_back = 7
export_dir = "~/Desktop/kakao-exports"    # .txt fallback folder
schedule_hours = 6
exclude_rooms = []

[kakao.nickname_to_name]
# "카톡닉네임" = "실명"

[slack]
enabled = false
sync_channels = []          # empty = all joined channels
sync_days_back = 7
poll_interval_minutes = 30

[telegram_bot]
enabled = true
allowed_user_ids = []
assistant_model = "claude"

[gdrive]
enabled = true
watch_paths = [
    "~/Library/CloudStorage/GoogleDrive-user@gmail.com/My Drive/Recordings",
]

[gcal]
enabled = true
calendar_ids = ["primary"]
schedule_minutes = 15

[web]
enabled = true
summary_model = "claude"

[stt]
model = "large-v3-turbo"
compute_type = "int8"
device = "cpu"
language = "ko"

[llm]
providers = ["claude", "ollama"]
daily_token_limit = 1_200_000

[llm.claude]
model = "claude-sonnet-4-6"

[llm.ollama]
model = "gemma2:9b"
base_url = "http://localhost:11434"

[search]
db_path = "~/.onlime/lancedb"
embedding_model = "BAAI/bge-m3"

[routing.routes]
"#aip" = "70-projects/borromeo"
"#borromeo" = "70-projects/borromeo"
"#boromeo" = "70-projects/borromeo"
"#chamchi" = "70-projects/chamchi"
"#thehackathon" = "70-projects/hackathon"
"#nextnobel" = "70-projects/next_nobel"
"#philosophy" = "70-projects/philosophy"

[scheduler]
enabled = true
morning_brief_hour = 8
daily_summary_hour = 23

[server]
host = "127.0.0.1"
port = 8000

[names]
known_contacts = []

[names.email_to_name]
# "user@example.com" = "홍길동"
