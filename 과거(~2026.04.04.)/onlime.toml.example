# Onlime 설정 파일
# 환경변수로 오버라이드 가능: ONLIME_VAULT_ROOT, ONLIME_TIMEZONE 등

[vault]
root = "/Users/cdiseetheeye/Documents/Obsidian_sinc"
meeting_dir = "1. INPUT/Meeting"
daily_dir = "2. OUTPUT/Daily"
inbox_dir = "1. INPUT/Inbox"
people_dir = "1. INPUT/People"
entity_dir = "1. Input"
entity_watchlist = ["세바시", "토스", "더존바이오", "흑백요리사"]

[state]
dir = "~/.config/onlime"

[gcal]
calendar_ids = ["primary", "seetheeye@chamchi.kr"]
sync_days_back = 7
sync_days_forward = 14

[plaud]
api_base = "https://api-apne1.plaud.ai"

[general]
timezone = "Asia/Seoul"
min_overlap_ratio = 0.3

[kakao]
# 카카오톡 닉네임 → 실명 매핑
[kakao.nickname_to_name]
# "카톡닉네임" = "실명"
# 예: "동인이" = "최동인"

[slack]
bot_token = ""
sync_channels = []      # 비어있으면 joined 채널 전부
sync_days_back = 3650

[telegram]
api_id = 0
api_hash = ""
phone = ""
session_dir = "~/.config/onlime"
sync_chats = []         # 비어있으면 최근 대화 전부
sync_days_back = 3650

[recording_sync]
enabled = false
watch_dir = "~/Recordings/synced"
extensions = [".m4a", ".wav", ".mp3", ".ogg", ".3gp", ".amr"]
auto_note = true   # 새 녹음 감지 시 자동 Obsidian 노트 생성

[messaging]
# 수집할 앱 패키지 목록
apps = ["com.kakao.talk", "com.Slack", "org.telegram.messenger", "com.instagram.android"]
# 무시할 채팅방 이름 (오픈채팅방 등)
ignore_rooms = []

[names]
# 이메일 매핑에 없는 외부 미팅 참가자 (실제 만나는 사람만)
known_contacts = ["이준석", "이경주", "우수한", "이보영", "김석기", "양승현", "김소희", "박하나", "강준서", "조용민"]

# 이메일 → 옵시디언 이름 매핑
[names.email_to_name]
"seetheeye@chamchi.kr" = "최동인"
"jh.shim@chamchi.kr" = "심정혁"
"uk.young@chamchi.kr" = "김욱영"
"wnsqud70@chamchi.kr" = "김민재_참치개발자"
